# ==============================================================================
# [공통 / 모노레포 루트]
# Docker Compose 및 인프라 공유 설정
# docker-compose.yml 에서 직접 참조됩니다.
# ==============================================================================

NODE_ENV=production

# PostgreSQL (docker-compose db 서비스)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=community_db


# ==============================================================================
# [API] apps/api/.env
# NestJS 백엔드 서버
# ==============================================================================

# 서버
PORT=4000
DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/community_db

# Redis (BullMQ 작업 큐 / 캐시)
# 설정하지 않으면 캐시 비활성화, BullMQ는 redis://localhost:6379 기본값 사용
REDIS_URL=

# 인증
JWT_SECRET=your-very-secret-key-change-this

# URL (CORS 및 OAuth 콜백 구성에 사용)
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# 소셜 로그인 — Google
# https://console.cloud.google.com 에서 OAuth 2.0 클라이언트 발급
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# 소셜 로그인 — Kakao
# https://developers.kakao.com 에서 앱 등록 후 발급
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:4000/auth/kakao/callback

# 소셜 로그인 — Naver
# https://developers.naver.com 에서 앱 등록 후 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:4000/auth/naver/callback

# 파일 스토리지
# STORAGE_TYPE=supabase 이면 Supabase, 값이 없으면 로컬 디스크(/uploads) 사용
STORAGE_TYPE=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=images


# ==============================================================================
# [Web] apps/web/.env.local
# Next.js 프론트엔드
# NEXT_PUBLIC_* 변수는 빌드 시 번들에 포함됩니다 (브라우저에 노출됨)
# ==============================================================================

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 애널리틱스 (선택)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_CONSOLE_ID=
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_CLARITY_ID=
